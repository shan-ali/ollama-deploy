# Ollama
OLLAMA_MODELS="llama3.2:3b,qwen3.5:4b,gemma3:4b,mistral:7b,tinyllama:latest"
OLLAMA_IMAGE="ollama/ollama:latest"
OLLAMA_IMAGE_AMD="ollama/ollama:rocm"
OLLAMA_CONTAINTER_NAME="ollama"
OLLAMA_PULL_POLICY="missing"
OLLAMA_HOST_PORT="11434"
OLLAMA_VOLUMES="ollama:/root/.ollama"
OLLAMA_RESTART="unless-stopped"
OLLAMA_HOST="http://${OLLAMA_CONTAINTER_NAME}:${OLLAMA_HOST_PORT}"

# Ollama Metrics
OLLAMA_METRICS_IMAGE="ghcr.io/norskhelsenett/ollama-metrics:latest"
OLLAMA_METRICS_CONTAINTER_NAME="ollama-metrics"
OLLAMA_METRICS_HOST_PORT="11435"
OLLAMA_METRICS_HOST="http://${OLLAMA_METRICS_CONTAINTER_NAME}:${OLLAMA_METRICS_HOST_PORT}"

# Open WebUI
OPEN_WEBUI_IMAGE="ghcr.io/open-webui/open-webui:main"
OPEN_WEBUI_HOST_PORT="8080"

# Prometheus
PROMETHEUS_IMAGE="prom/prometheus:main"
PROMETHEUS_HOST_PORT="9090"

# Grafana
GF_IMAGE="grafana/grafana:main"
GF_HOST_PORT="3000"
GF_SECURITY_ADMIN_PASSWORD="admin"
