# Ollama
OLLAMA_MODELS="llama3.2:3b,qwen3.5:4b,gemma3:4b,mistral:7b,tinyllama:latest"

OLLAMA_IMAGE="ollama/ollama:latest"
OLLAMA_IMAGE_AMD="ollama/ollama:rocm"

OLLAMA_CONTAINTER_NAME="ollama"
OLLAMA_PULL_POLICY="missing"
OLLAMA_PORTS="11434:11434"
OLLAMA_VOLUMES="ollama:/root/.ollama"
OLLAMA_RESTART="unless-stopped"

OLLAMA_HOST="http://ollama:11434"

# Open WebUI
OPEN_WEBUI_IMAGE="ollama/webui:latest"
OPEN_WEBUI_PORTS="8080:8080"

# Prometheus
PROMETHEUS_IMAGE="prom/prometheus:latest"
PROMETHEUS_PORTS="9090:9090"

# Grafana
GF_IMAGE="grafana/grafana:latest"
GF_PORTS="3000:3000"
GF_SECURITY_ADMIN_PASSWORD="admin"
